classDiagram
    class Task {
        +str description
        +str time
        +str frequency
        +bool completed
        +mark_complete() void
        +next_occurrence() Task
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task: Task) void
        +list_tasks() list~Task~
        +task_count() int
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet: Pet) void
        +get_all_tasks() list
    }

    class Scheduler {
        +Owner owner
        +sort_by_time() list
        +filter_tasks(pet, completed) list
        +detect_conflicts() list~str~
        +complete_task(task: Task) void
        +todays_schedule() str
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "1" Owner : schedules for
